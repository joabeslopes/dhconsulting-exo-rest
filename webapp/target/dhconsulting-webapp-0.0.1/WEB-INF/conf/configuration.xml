<configuration
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.exoplatform.org/xml/ns/kernel_1_2.xsd http://www.exoplatform.org/xml/ns/kernel_1_2.xsd"
    xmlns="http://www.exoplatform.org/xml/ns/kernel_1_2.xsd">

  <component>
    <key>br.com.dhconsulting.rest.UltimaSprint</key>
    <type>br.com.dhconsulting.rest.UltimaSprint</type>
  </component>

  <external-component-plugins>
    <target-component>org.exoplatform.container.definition.PortalContainerConfig</target-component>
    <component-plugin>
      <name>Add dhconsulting to portal</name>
      <set-method>registerSelectedRestWebapps</set-method>
      <type>org.exoplatform.container.definition.PortalContainerDefinitionPlugin</type>
      <init-params>
        <values-param>
          <name>rest-webapps</name>
          <value>dhconsulting-webapp</value>
        </values-param>
      </init-params>
    </component-plugin>
  </external-component-plugins>
</configuration>